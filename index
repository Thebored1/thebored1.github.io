  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link
    href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Sora:wght@300;400;500;600&display=swap"
    rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box
    }

    :root {
      --bg: #0d0d0d;
      --bg2: #141414;
      --bg3: #1a1a1a;
      --border: #2a2a2a;
      --border2: #333;
      --text: #e8e6e0;
      --text2: #888;
      --text3: #555;
      --accent: #4ade80;
      --accent2: #22c55e
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Sora', sans-serif;
      font-size: 15px;
      line-height: 1.7;
      min-height: 100vh
    }

    a {
      color: inherit;
      text-decoration: none
    }



    .nav-links {
      display: flex;
      gap: 1.5rem
    }

    .nav-links a {
      font-size: 13px;
      color: var(--text2);
      transition: color .2s
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: var(--text)
    }

    .nav-logo {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      color: var(--accent)
    }

    main {
      max-width: 760px;
      margin: 0 auto;
      padding: 3rem 2rem
    }

    .hero {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      align-items: start;
      padding: 2rem;
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 12px;
      margin-bottom: 2.5rem
    }

    .hero-name {
      font-size: 1.6rem;
      font-weight: 600;
      margin-bottom: .25rem;
      letter-spacing: -.02em
    }

    .hero-role {
      font-size: 13px;
      color: var(--accent);
      font-family: 'JetBrains Mono', monospace;
      margin-bottom: 1.2rem
    }

    .hero-bio {
      color: var(--text2);
      font-size: 14px;
      line-height: 1.8;
      margin-bottom: 1.2rem
    }

    .hero-bio strong {
      color: var(--text);
      font-weight: 500
    }

    .socials {
      display: flex;
      align-items: center;
      gap: .75rem;
      margin-bottom: 1.2rem;
      flex-wrap: wrap
    }

    .social-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border: 1px solid var(--border2);
      border-radius: 8px;
      color: var(--text2);
      transition: all .2s;
      font-size: 14px;
      cursor: pointer;
      background: transparent;
      flex-shrink: 0
    }

    .social-btn:hover {
      border-color: var(--accent);
      color: var(--accent)
    }

    .social-btn.active {
      border-color: var(--accent);
      color: var(--accent)
    }

    .phone-expand {
      display: flex;
      align-items: center;
      gap: 8px;
      overflow: hidden;
      max-width: 0;
      opacity: 0;
      transition: max-width .35s ease, opacity .25s ease
    }

    .phone-expand.open {
      max-width: 200px;
      opacity: 1
    }

    .phone-num {
      font-size: 12px;
      font-family: 'JetBrains Mono', monospace;
      color: var(--accent);
      white-space: nowrap
    }

    .copy-hint {
      font-size: 11px;
      color: var(--text3);
      white-space: nowrap;
      transition: color .2s
    }

    .copy-hint.copied {
      color: var(--accent)
    }

    .btn {
      display: inline-block;
      padding: .5rem 1.1rem;
      border: 1px solid var(--border2);
      border-radius: 8px;
      font-size: 13px;
      color: var(--text2);
      transition: all .2s;
      cursor: pointer;
      font-family: 'Sora', sans-serif;
      background: transparent
    }

    .btn:hover {
      border-color: var(--accent);
      color: var(--accent)
    }

    .avatar-initials {
      font-size: 2rem;
      font-weight: 600;
      color: var(--accent);
      font-family: 'JetBrains Mono', monospace
    }

    section {
      margin-bottom: 2.5rem
    }

    .section-title {
      font-size: 1rem;
      font-weight: 500;
      margin-bottom: 1.2rem;
      padding-bottom: .6rem;
      border-bottom: 1px solid var(--border)
    }

    .skills-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .75rem
    }

    .skill-row {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: .75rem 1rem
    }

    .skill-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--text3);
      margin-bottom: .3rem;
      font-family: 'JetBrains Mono', monospace
    }

    .skill-val span {
      background: var(--bg3);
      border: 1px solid var(--border2);
      border-radius: 4px;
      padding: 2px 7px;
      font-size: 11px;
      margin-right: 4px;
      margin-bottom: 4px;
      display: inline-block;
      font-family: 'JetBrains Mono', monospace;
      color: var(--text);
      transition: all .2s
    }

    .skill-val span:hover {
      border-color: var(--accent);
      color: var(--accent)
    }

    .exp-list {
      display: flex;
      flex-direction: column;
      gap: .75rem
    }

    .exp-card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      transition: border-color .2s
    }

    .exp-card:hover {
      border-color: var(--border2)
    }

    .exp-header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 1rem 1.2rem;
      cursor: pointer
    }

    .exp-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: var(--bg3);
      border: 1px solid var(--border2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      flex-shrink: 0
    }

    .exp-info {
      flex: 1;
      min-width: 0
    }

    .exp-company {
      font-weight: 500;
      font-size: 14px
    }

    .exp-role {
      font-size: 12px;
      color: var(--text2)
    }

    .exp-meta {
      text-align: right;
      flex-shrink: 0
    }

    .exp-date {
      font-size: 11px;
      color: var(--text3);
      font-family: 'JetBrains Mono', monospace
    }

    .exp-type {
      font-size: 11px;
      color: var(--text3)
    }

    .exp-chevron {
      color: var(--text3);
      font-size: 12px;
      margin-left: 8px;
      transition: transform .2s
    }

    .exp-body {
      padding: 0 1.2rem;
      max-height: 0;
      overflow: hidden;
      transition: max-height .35s ease, padding .2s
    }

    .exp-body.open {
      padding: 0 1.2rem 1.2rem;
      max-height: 800px
    }

    .exp-body ul {
