      font-size: 14px;
      color: var(--accent);
      margin-bottom: .3rem
    }

    .project-desc {
      font-size: 12px;
      color: var(--text2);
      line-height: 1.7
    }

    footer {
      max-width: 760px;
      margin: 0 auto;
      padding: 1.5rem 2rem 2.5rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center
    }

    .footer-copy {
      font-size: 12px;
      color: var(--text3);
      font-family: 'JetBrains Mono', monospace
    }


    .exp-header.open .exp-chevron {
      transform: rotate(90deg)
    }

    @media(max-width:600px) {
